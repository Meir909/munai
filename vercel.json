{
  "version": 2,
  "framework": null,
  "buildCommand": "cd munai-digital-oilfield-ops-main && npm install && npm run build:spa",
  "outputDirectory": "munai-digital-oilfield-ops-main/dist",
  "installCommand": "pip install -r api/requirements.txt --break-system-packages",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30,
      "excludeFiles": "**/__pycache__/**|**/*.pyc|**/*.pyo|**/*.dist-info/**|**/*.egg-info/**|**/tests/**|**/test/**|**/_pytest/**|**/pytest/**|**/pip/**|**/setuptools/**|**/wheel/**|**/pkg_resources/**|**/lib2to3/**|**/idlelib/**|**/tkinter/**|**/turtle*|**/unittest/**|**/distutils/**|**/ensurepip/**|**/venv/**|**/xmlrpc/**|**/multiprocessing/**|**/concurrent/**|**/ctypes/**|**/curses/**|**/dbm/**|**/lib-dynload/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "DATABASE_URL": "sqlite:////tmp/munai.db",
    "SECRET_KEY": "munai-production-secret-key-2026-change-me",
    "ALGORITHM": "HS256",
    "ACCESS_TOKEN_EXPIRE_MINUTES": "10080",
    "VITE_API_URL": "/api"
  }
}
